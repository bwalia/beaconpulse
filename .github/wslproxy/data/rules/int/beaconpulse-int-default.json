{
  "id": "beaconpulse-int-default",
  "name": "beaconpulse-int-default",
  "profile_id": "int",
  "priority": 1,
  "rules_tags": [
    "beaconpulse",
    "int"
  ],
  "match": {
    "rules": {
      "path": "/",
      "path_key": "starts_with"
    },
    "response": {
      "code": 305,
      "redirect_uri": "192.168.11.121:32100",
      "strip_path": false,
      "backends": [
        {
          "address": "192.168.11.121:32100",
          "weight": 50,
          "label": "k3s-node-0"
        },
        {
          "address": "192.168.11.132:32100",
          "weight": 50,
          "label": "k3s-node-1"
        }
      ],
      "routing": {
        "mode": "weighted"
      }
    }
  },
  "servers": [
    "host:int.beaconpulse.net"
  ]
}
