{
  "id": "beaconpulse-prod-default",
  "name": "beaconpulse-prod-default",
  "profile_id": "prod",
  "priority": 1,
  "rules_tags": ["beaconpulse", "prod"],
  "match": {
    "rules": {
      "path": "/",
      "path_key": "starts_with",
      "jwt_token_validation": "equals"
    },
    "response": {
      "code": 305,
      "redirect_uri": "10.8.0.2:80",
      "strip_path": false,
      "backends": [
        { "address": "10.8.0.2:80", "weight": 100, "label": "k3s1 debworker00 (beacon pods pinned here)" },
        { "address": "10.8.0.3:80", "weight": 100, "label": "k3s1 control-plane" },
        { "address": "10.8.0.4:80", "weight": 100, "label": "k3s1 debian001" },
        { "address": "10.8.0.5:80", "weight": 100, "label": "k3s1 debian002" },
        { "address": "10.8.0.6:80", "weight": 100, "label": "k3s1 debian003" },
        { "address": "10.8.0.7:80", "weight": 100, "label": "k3s1 debian004" },
        { "address": "10.8.0.8:80", "weight": 100, "label": "k3s1 debian005" },
        { "address": "10.8.0.10:80", "weight": 100, "label": "k3s1 debian006" },
        { "address": "10.8.0.11:80", "weight": 100, "label": "k3s1 debian007" }
      ],
      "routing": {
        "mode": "least_conn"
      }
    }
  },
  "servers": [
    "host:int.beaconpulse.net",
    "host:test.beaconpulse.net",
    "host:acc.beaconpulse.net",
    "host:beaconpulse.net"
  ]
}
