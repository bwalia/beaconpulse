{
  "id": "beaconpulse-prod-default",
  "name": "beaconpulse-prod-default",
  "profile_id": "prod",
  "priority": 1,
  "rules_tags": ["beaconpulse", "prod"],
  "match": {
    "rules": {
      "path": "/",
      "path_key": "starts_with",
      "jwt_token_validation": "equals"
    },
    "response": {
      "code": 305,
      "redirect_uri": "13.42.188.136:80",
      "strip_path": false,
      "backends": [
        {
          "address": "13.42.188.136:80",
          "weight": 100,
          "label": "k3s1 traefik ingress (wslproxy class); beacon pods pinned to debworker00"
        }
      ],
      "routing": {
        "mode": "least_conn"
      }
    }
  },
  "servers": [
    "host:int.beaconpulse.net",
    "host:test.beaconpulse.net",
    "host:acc.beaconpulse.net",
    "host:beaconpulse.net"
  ]
}
