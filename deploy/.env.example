# Gateway configuration for docker-compose (single-port setup).
#
# Beacon runs everything behind an nginx gateway on ONE host port. Postgres and
# Redis are also published for local debugging; change any that collide.
#
# Usage: copy to `.env` in the directory you run compose from, or pass inline:
#   BEACON_GATEWAY_PORT=9000 make up

BEACON_GATEWAY_PORT=8090
BEACON_POSTGRES_PORT=5432
BEACON_REDIS_PORT=6379

# ---------------------------------------------------------------------------
# AI alert enrichment (optional). When enabled, firing alerts are triaged by an
# Ollama-compatible model (assessed impact + likely cause + suggested fix) before
# being delivered. Best-effort: if the model is slow/down the alert still ships.
# ---------------------------------------------------------------------------
BEACON_AI_ENABLED=false
BEACON_AI_BASE_URL=https://ollama.example.com   # endpoint root, no trailing slash, no /api
BEACON_AI_MODEL=                                # a model installed on that endpoint, e.g. llama3.1
BEACON_AI_API_KEY=                              # x-api-key if the endpoint requires one
BEACON_AI_TIMEOUT=20s                           # per-alert budget for the model call
