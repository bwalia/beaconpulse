# Gateway configuration for docker-compose (single-port setup).
#
# Beacon runs everything behind an nginx gateway on ONE host port. Postgres and
# Redis are also published for local debugging; change any that collide.
#
# Usage: copy to `.env` in the directory you run compose from, or pass inline:
#   BEACON_GATEWAY_PORT=9000 make up

BEACON_GATEWAY_PORT=8090
BEACON_POSTGRES_PORT=5432
BEACON_REDIS_PORT=6379
