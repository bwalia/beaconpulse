# ---- Go ----
/backend/bin/
/backend/tmp/
*.test
*.out
coverage.*
vendor/

# ---- Node / Next.js ----
node_modules/
/frontend/.next/
/frontend/out/
/frontend/build/
.pnpm-store/
*.tsbuildinfo
next-env.d.ts

# ---- Env / secrets ----
.env
.env.*
!.env.example
*.pem
*.key
!deploy/**/*.example

# ---- Runtime state (generated by control plane) ----
# Keep the directory (for the bind mount) but ignore the generated files.
/deploy/prometheus/generated/*
!/deploy/prometheus/generated/.gitkeep
/data/

# ---- Editor / OS ----
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Plaintext behind the SealedSecrets (seal-secrets.sh). NEVER commit.
deploy/.secrets/

# The sealed-secrets PUBLIC sealing certificate. Safe (and necessary) to commit:
# sealing is asymmetric, so this lets anyone re-seal without cluster access. The
# matching PRIVATE key never leaves the in-cluster controller.
!deploy/sealed/sealing-cert.pem
